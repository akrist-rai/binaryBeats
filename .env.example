# Copy to .env.local for local overrides (Vite loads .env.local automatically
# and it's gitignored). Not needed for local dev by default — the Vite dev
# server proxies /api to http://localhost:4000 (see vite.config.ts).
#
# Set this in Vercel's project settings when the frontend and backend are on
# different domains (e.g. a Render-hosted API). Leave unset for a same-origin
# deploy. See DEPLOYMENT.md.
VITE_API_URL=
