# Neon PostgreSQL connection string
# Get it from: https://neon.tech → your project → Connection Details
DATABASE_URL=postgresql://neondb_owner:npg_qnb3v4HPJzBg@ep-ancient-frog-az48uj49-pooler.c-3.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Separate Neon project for the `users` table only. The dataset DB above is
# already at its free-tier 512MB storage cap (mostly the `tests` table), so
# auth gets its own small project instead of fighting it for space:
#   1. https://neon.tech → New Project (free tier is plenty for just `users`)
#   2. Copy the connection string from Connection Details, paste it below
AUTH_DATABASE_URL=

# Signs the session cookie (login.html / GET /api/auth/me). Any change
# invalidates every existing session. Generated with `openssl rand -hex 32`.
SESSION_SECRET=87f7d01f756693c36c8b8a86a2de8752cf335a0825e7831d46c94d8b8567db25

# Google Sign-In (Identity Services). Leave blank to disable the Google button
# on login.html — it hides itself automatically when this is unset.
#
# To create one:
#   1. https://console.cloud.google.com/apis/credentials (create a project if needed)
#   2. "Create Credentials" → "OAuth client ID" → Application type: "Web application"
#   3. Under "Authorized JavaScript origins" add the URLs you'll load login.html from,
#      e.g. http://localhost:5173 (Vite dev) and your production URL
#   4. Copy the generated Client ID below (the Client Secret is NOT needed —
#      this flow only verifies the ID token server-side)
GOOGLE_CLIENT_ID=
